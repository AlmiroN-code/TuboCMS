<div class="overflow-hidden hover:shadow-sm transition group video-card mb-4">
    <a href="{{ path('video_detail', {slug: video.slug}) }}">
        <div class="thumbnail">
            {% if video.poster %}
            <img src="/media/{{ video.poster }}" alt="{{ video.title }}" class="poster-image" loading="lazy" data-lazy-src="/media/{{ video.poster }}">
            {% else %}
                <div class="poster-placeholder absolute inset-0 w-full h-full flex items-center justify-center bg-gradient-to-br from-red-500 to-orange-500 text-white font-bold">
                    <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                    </svg>
                </div>
            {% endif %}
            
    {% if video.preview %}
                <video src="/media/{{ video.preview }}" alt="{{ video.title }}" class="preview-video" muted loop preload="none" data-lazy-video="/media/{{ video.preview }}"></video>
            {% endif %}
            
            {% if video.duration > 0 %}
                <span class="duration">
                    {{ video.durationFormatted }}
                </span>
            {% endif %}
            
            <!-- Video action buttons -->
            <div class="video-actions">
                <div id="wl-btn-90" class="watch-later-btn" role="button" aria-label="{{ 'video.watch_later'|trans }}" title="{{ 'video.watch_later'|trans }}" hx-post="/videos/htmx/aaaaaa/watch-later/" hx-headers="{&quot;X-CSRFToken&quot;: &quot;gszx2KVDCRSdoa84x5FulEw5jJwczuT4&quot;}" hx-target="#wl-btn-90" hx-swap="outerHTML" hx-on:click="event.preventDefault(); event.stopPropagation();">
    <i class="fas fa-clock"></i>
 </div>

            </div>
        </div>
    </a>
    <div class="video-info">
        <div class="video-details">
            <div class="video-title text-sm text-gray-700">
                <a href="{{ path('video_detail', {slug: video.slug}) }}">{{ video.title }}</a>
            </div>
            <div class="video-meta">
                <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                    {{ video.viewsCount|locale_number }}
                </span>
                <span>{{ video.createdAt|time_ago }}</span>
            </div>
            
        </div>
    </div>
</div>