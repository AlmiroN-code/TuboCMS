{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard{% endblock %}
{% block page_title %}Dashboard{% endblock %}

{% block content %}
{# Storage Dashboard Widget - Requirements 6.1, 6.2 #}
{% if storage_stats is defined and storage_stats|length > 0 %}
<div class="bg-white rounded-lg shadow mb-8">
    <div class="px-6 py-4 border-b flex items-center justify-between">
        <div>
            <h3 class="text-lg font-semibold text-gray-900">Хранилища</h3>
            <p class="text-sm text-gray-600">Использование дискового пространства</p>
        </div>
        <a href="{{ path('admin_storage') }}" class="text-blue-600 hover:text-blue-800 text-sm">
            Управление →
        </a>
    </div>
    <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for key, stat in storage_stats %}
            <div class="border rounded-lg p-4 {% if stat.warningExceeded %}border-orange-300 bg-orange-50{% else %}border-gray-200{% endif %}">
                <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center">
                        <span class="text-xl mr-2">
                            {% if stat.type == 'local' %}💾
                            {% elseif stat.type == 'ftp' %}📡
                            {% elseif stat.type == 'sftp' %}🔐
                            {% elseif stat.type == 'http' %}🌐
                            {% else %}📦{% endif %}
                        </span>
                        <span class="font-medium text-gray-900">{{ stat.name }}</span>
                    </div>
                    <span class="text-xs px-2 py-1 rounded-full 
                        {% if stat.type == 'local' %}bg-gray-100 text-gray-600
                        {% elseif stat.type == 'ftp' %}bg-blue-100 text-blue-600
                        {% elseif stat.type == 'sftp' %}bg-green-100 text-green-600
                        {% elseif stat.type == 'http' %}bg-purple-100 text-purple-600
                        {% else %}bg-gray-100 text-gray-600{% endif %}">
                        {{ stat.type|upper }}
                    </span>
                </div>
                
                <div class="text-sm text-gray-600 mb-3">
                    <span class="font-semibold text-gray-900">{{ stat.filesCount }}</span> файлов • 
                    <span class="font-semibold text-gray-900">{{ stat.totalSizeFormatted }}</span>
                </div>
                
                {% if stat.quota is not null %}
                {# Quota information - Requirement 6.2 #}
                <div class="mt-3">
                    <div class="flex justify-between text-xs text-gray-500 mb-1">
                        <span>Использовано: {{ stat.quotaUsedFormatted }}</span>
                        {% if stat.quotaTotalFormatted %}
                        <span>Всего: {{ stat.quotaTotalFormatted }}</span>
                        {% endif %}
                    </div>
                    {% if stat.usagePercent is not null %}
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="h-2 rounded-full {% if stat.warningExceeded %}bg-orange-500{% elseif stat.usagePercent > 60 %}bg-yellow-500{% else %}bg-green-500{% endif %}" 
                             style="width: {{ min(stat.usagePercent, 100) }}%"></div>
                    </div>
                    <div class="flex justify-between text-xs mt-1">
                        <span class="{% if stat.warningExceeded %}text-orange-600 font-semibold{% else %}text-gray-500{% endif %}">
                            {{ stat.usagePercent|number_format(1) }}% использовано
                        </span>
                        {% if stat.quotaAvailableFormatted %}
                        <span class="text-gray-500">Свободно: {{ stat.quotaAvailableFormatted }}</span>
                        {% endif %}
                    </div>
                    {% if stat.warningExceeded %}
                    <div class="mt-2 flex items-center text-orange-600 text-xs">
                        <span class="mr-1">⚠️</span>
                        <span>Использование превышает 80%</span>
                    </div>
                    {% endif %}
                    {% endif %}
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endif %}

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6">
        <div class="text-gray-600 text-xs uppercase tracking-wide">Total Videos</div>
        <div class="text-2xl font-bold text-gray-900 mt-1">{{ stats.total_videos ?? 0 }}</div>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6">
        <div class="text-gray-600 text-xs uppercase tracking-wide">Users</div>
        <div class="text-2xl font-bold text-gray-900 mt-1">{{ stats.total_users ?? 0 }}</div>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6">
        <div class="text-gray-600 text-xs uppercase tracking-wide">Views</div>
        <div class="text-2xl font-bold text-gray-900 mt-1">{{ stats.total_views ?? 0 }}</div>
    </div>
    
    <div class="bg-white rounded-lg shadow p-6">
        <div class="text-gray-600 text-xs uppercase tracking-wide">Comments</div>
        <div class="text-2xl font-bold text-gray-900 mt-1">{{ stats.total_comments ?? 0 }}</div>
    </div>
    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
            <div class="p-2 bg-blue-100 rounded-lg">
                <span class="text-2xl">📝</span>
            </div>
            <div class="ml-4">
                <p class="text-sm font-medium text-gray-600">Total Posts</p>
                <p class="text-2xl font-semibold text-gray-900">8</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
            <div class="p-2 bg-green-100 rounded-lg">
                <span class="text-2xl">✅</span>
            </div>
            <div class="ml-4">
                <p class="text-sm font-medium text-gray-600">Published</p>
                <p class="text-2xl font-semibold text-gray-900">8</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
            <div class="p-2 bg-yellow-100 rounded-lg">
                <span class="text-2xl">📄</span>
            </div>
            <div class="ml-4">
                <p class="text-sm font-medium text-gray-600">Drafts</p>
                <p class="text-2xl font-semibold text-gray-900">0</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
            <div class="p-2 bg-purple-100 rounded-lg">
                <span class="text-2xl">📁</span>
            </div>
            <div class="ml-4">
                <p class="text-sm font-medium text-gray-600">Categories</p>
                <p class="text-2xl font-semibold text-gray-900">4</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
            <div class="p-2 bg-indigo-100 rounded-lg">
                <span class="text-2xl">🏷️</span>
            </div>
            <div class="ml-4">
                <p class="text-sm font-medium text-gray-600">Tags</p>
                <p class="text-2xl font-semibold text-gray-900">20</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
            <div class="p-2 bg-pink-100 rounded-lg">
                <span class="text-2xl">👤</span>
            </div>
            <div class="ml-4">
                <p class="text-sm font-medium text-gray-600">Users</p>
                <p class="text-2xl font-semibold text-gray-900">2</p>
            </div>
        </div>
    </div>

        <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
            <div class="p-2 bg-blue-100 rounded-lg">
                <span class="text-2xl">💬</span>
            </div>
            <div class="ml-4">
                <p class="text-sm font-medium text-gray-600">Comments</p>
                <p class="text-2xl font-semibold text-gray-900">0</p>
            </div>
        </div>
    </div>
    
        <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
            <div class="p-2 bg-orange-100 rounded-lg">
                <span class="text-2xl">⏳</span>
            </div>
            <div class="ml-4">
                <p class="text-sm font-medium text-gray-600">Pending</p>
                <p class="text-2xl font-semibold text-gray-900">0</p>
            </div>
        </div>
    </div>
    
      
</div>


<div class="bg-white rounded-lg shadow">

<div class="px-6 py-4 border-b">
        <h3 class="text-lg font-semibold text-gray-900">Recent Videos</h3>
        <p class="text-sm text-gray-600">Recently added videos</p>
        
    </div>
<div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
<thead class="bg-gray-50">
                    <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Poster</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            </tr>
        </thead>
<tbody class="bg-white divide-y divide-gray-200">
    {% for video in recent_videos %}
<tr class="hover:bg-gray-50">
	<td class="px-6 py-4">
		{% if video.poster %}
                    <img src="/media/{{ video.poster }}" alt="{{ video.title }}" class="w-24 h-16 object-cover">
                {% else %}
                    <div class="w-24 h-16 bg-gray-100 flex items-center justify-center">
                        <span class="text-gray-400 text-xs">No poster</span>
                    </div>
                {% endif %}
	</td>
	<td class="px-6 py-4 whitespace-nowrap">
		<div class="text-sm text-gray-900">{{ video.title }}</div>
		<div class="text-sm text-gray-500">{{ video.createdAt|date('d.m.Y H:i') }}</div>
		<div class="text-sm text-gray-500">{{ video.durationFormatted }}</div>
	</td>
	<td class="px-6 py-4 whitespace-nowrap">
		<span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full" style="background-color: #3B82F620; color: #3B82F6">
		{{ video.createdAt|date('d.m.Y H:i') }}
		</span>
        <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full" style="background-color: #3B82F620; color: #3B82F6">
		{{ video.category ? video.category.name : '-' }}</span>
	</td>
	<td class="px-6 py-4 whitespace-nowrap">
		<span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full" style="background-color: #3B82F620; color: #3B82F6">
		{% if video.processingStatus != 'completed' %}
                        <a href="{{ path('admin_videos_process', {id: video.id}) }}" class="text-blue-600 hover:text-blue-900">Process</a>
                    {% endif %}
		</span>
	</td>
	<td class="px-6 py-4 whitespace-nowrap">
		<span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800 
		{% if video.status == 'published' %}
                        {% elseif video.status == 'processing' %} bg-blue-600
                        {% else %}
                        bg-gray-600
                        {% endif %}">
                        {{ video.status }}
		</span>
	</td>
</tr>
        {% endfor %}
</tbody>
</table>


    
</div>
{% endblock %}
