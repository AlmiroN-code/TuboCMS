{% extends 'admin/base.html.twig' %}

{% block title %}Comments{% endblock %}
{% block page_title %}Comments{% endblock %}

{% block content %}
<div class="mb-6">
    <p class="text-gray-600">Total: {{ total }}</p>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Video</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Comment</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
            {% for comment in comments %}
            <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm">{{ comment.id }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">{{ comment.user.username }}</td>
                <td class="px-6 py-4 text-sm">
                    <a href="{{ path('video_detail', {slug: comment.video.slug}) }}" class="text-blue-600 hover:underline" target="_blank">
                        {{ comment.video.title|length > 50 ? comment.video.title|slice(0, 50) ~ '...' : comment.video.title }}
                    </a>
                </td>
                <td class="px-6 py-4 text-sm">
                    {{ comment.content|length > 100 ? comment.content|slice(0, 100) ~ '...' : comment.content }}
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">{{ comment.createdAt|date('d.m.Y H:i') }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                    <form method="post" action="{{ path('admin_comments_delete', {id: comment.id}) }}" class="inline" onsubmit="return confirm('Delete comment?')">
                        <button type="submit" class="text-red-600 hover:text-red-900">Delete</button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% if pages > 1 %}
<div class="mt-6 flex justify-center">
    <nav class="flex space-x-2">
        {% for p in 1..pages %}
            <a href="{{ path('admin_comments', {page: p}) }}" 
               class="px-4 py-2 rounded {{ p == page ? 'bg-blue-600 text-white' : 'bg-white text-gray-700 hover:bg-gray-100' }}">
                {{ p }}
            </a>
        {% endfor %}
    </nav>
</div>
{% endif %}
{% endblock %}
