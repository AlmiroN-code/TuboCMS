{% extends 'admin/base.html.twig' %}

{% block title %}SEO настройки{% endblock %}

{% block content %}
<div class="container mx-auto">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold">SEO настройки</h1>
        <a href="{{ path('admin_settings') }}" class="text-blue-600 hover:text-blue-800">
            ← Назад к настройкам
        </a>
    </div>
    
    <form method="POST" class="space-y-6">
        <div class="bg-white rounded-lg shadow p-6">
            <h2 class="text-xl font-semibold mb-4">Мета-теги для главной страницы</h2>
            
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Заголовок главной страницы</label>
                    <input type="text" name="seo_home_title" value="{{ settings.seo_home_title }}"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                           placeholder="Например: Лучший видеохостинг">
                    <p class="text-sm text-gray-500 mt-1">Будет использоваться в теге &lt;title&gt; на главной странице</p>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Описание сайта</label>
                    <textarea name="seo_home_description" rows="3"
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                              placeholder="Краткое описание вашего сайта для поисковых систем">{{ settings.seo_home_description }}</textarea>
                    <p class="text-sm text-gray-500 mt-1">Рекомендуемая длина: 150-160 символов</p>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Ключевые слова (через запятую)</label>
                    <input type="text" name="seo_home_keywords" value="{{ settings.seo_home_keywords }}"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                           placeholder="видео, хостинг, онлайн, смотреть">
                    <p class="text-sm text-gray-500 mt-1">Разделяйте ключевые слова запятыми</p>
                </div>
                
                <div class="border-t pt-4">
                    <div class="flex items-start">
                        <input type="checkbox" name="seo_home_only" value="1" id="seo_home_only"
                               {{ settings.seo_home_only ? 'checked' : '' }}
                               class="w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500 mt-1">
                        <label for="seo_home_only" class="ml-2 text-sm text-gray-700">
                            <span class="font-medium">Использовать указанные выше слова и описание только для главной страницы</span>
                            <p class="text-gray-500 mt-1">Если выключено, эти слова будут отображаться на страницах с не заданными подобными параметрами</p>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex justify-end gap-4">
            <a href="{{ path('admin_settings') }}" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
                Отмена
            </a>
            <button type="submit" class="px-6 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700">
                Сохранить настройки
            </button>
        </div>
    </form>
</div>
{% endblock %}
