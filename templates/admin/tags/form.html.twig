{% extends 'admin/base.html.twig' %}

{% block title %}{{ tag.id ? 'Edit Tag' : 'New Tag' }}{% endblock %}
{% block page_title %}{{ tag.id ? 'Edit Tag' : 'New Tag' }}{% endblock %}

{% block content %}
<div class="bg-white rounded-lg shadow p-6">
    <form method="post">
        <div class="space-y-6">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Name</label>
                <input type="text" name="name" value="{{ tag.name }}" required
                       class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <div class="flex space-x-4">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded">
                    Save
                </button>
                <a href="{{ path('admin_tags') }}" class="bg-gray-300 hover:bg-gray-400 text-gray-800 px-6 py-2 rounded">
                    Cancel
                </a>
            </div>
        </div>
    </form>
</div>
{% endblock %}
