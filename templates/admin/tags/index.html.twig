{% extends 'admin/base.html.twig' %}

{% block title %}Tags{% endblock %}
{% block page_title %}Tags{% endblock %}

{% block content %}
<div class="mb-6 flex justify-end">
    <a href="{{ path('admin_tags_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded">
        Add tag
    </a>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Slug</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Usage</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
            </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
            {% for tag in tags %}
            <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm">{{ tag.id }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">{{ tag.name }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ tag.slug }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">{{ tag.usageCount }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                    <a href="{{ path('admin_tags_edit', {id: tag.id}) }}" class="text-indigo-600 hover:text-indigo-900">Edit</a>
                    <form method="post" action="{{ path('admin_tags_delete', {id: tag.id}) }}" class="inline" onsubmit="return confirm('Delete tag?')">
                        <button type="submit" class="text-red-600 hover:text-red-900">Delete</button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
