{% extends 'admin/base.html.twig' %}

{% block title %}Модели{% endblock %}
{% block page_title %}Модели{% endblock %}

{% block content %}
<div class="mb-6 flex justify-between items-center">
    <p class="text-gray-600">Всего: {{ total }}</p>
    <a href="{{ path('admin_models_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded">
        Добавить модель
    </a>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Имя</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Slug</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Видео</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Действия</th>
            </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
            {% for model in models %}
            <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm">{{ model.id }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">{{ model.name }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{{ model.slug }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">{{ model.videosCount }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                    <a href="{{ path('admin_models_edit', {id: model.id}) }}" class="text-indigo-600 hover:text-indigo-900">Редактировать</a>
                    <form method="post" action="{{ path('admin_models_delete', {id: model.id}) }}" class="inline" onsubmit="return confirm('Удалить модель?')">
                        <button type="submit" class="text-red-600 hover:text-red-900">Удалить</button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% if pages > 1 %}
<div class="mt-6 flex justify-center">
    <nav class="flex space-x-2">
        {% for p in 1..pages %}
            <a href="{{ path('admin_models', {page: p}) }}" 
               class="px-4 py-2 rounded {{ p == page ? 'bg-blue-600 text-white' : 'bg-white text-gray-700 hover:bg-gray-100' }}">
                {{ p }}
            </a>
        {% endfor %}
    </nav>
</div>
{% endif %}
{% endblock %}
