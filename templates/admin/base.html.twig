<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token('htmx') }}">
    <title>{% block title %}Admin Panel{% endblock %}{% if setting('append_site_name_to_title') %} - {{ site_name() }}{% endif %}</title>
    
    {% if site_favicon() %}
        <link rel="icon" type="image/x-icon" href="{{ site_favicon() }}">
    {% endif %}
    
    {% block stylesheets %}{% endblock %}
    {{ encore_entry_link_tags('app') }}
    {{ encore_entry_script_tags('app') }}
</head>
<body class="bg-gray-100">
    <div class="flex h-screen">
        <!-- Sidebar -->
        <aside class="w-56 bg-gray-800 border-r border-gray-800 min-h-screen">
            <div class="p-3 border-b border-gray-800">
                <div class="flex items-center gap-2">
                    {% if site_logo() %}
                        <img src="{{ site_logo() }}" alt="{{ site_name() }}" class="h-7 object-contain">
                    {% else %}
                        <div class="w-7 h-7 bg-blue-600 flex items-center justify-center text-white font-bold text-xs">
                            {{ site_name()|slice(0, 1)|upper }}
                        </div>
                    {% endif %}
                    <div>
                        <h1 class="text-sm font-semibold text-white">{{ site_name() }}</h1>
                        <p class="text-xs text-gray-400">Admin Panel</p>
                    </div>
                </div>
            </div>
            
            <nav class="py-2">
                <a href="{{ path('admin_dashboard') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                    </svg>
                    Dashboard
                </a>

                <div class="mt-3">
                    <div class="px-3 py-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Content</div>
                    <a href="{{ path('admin_videos') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_videos' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                        </svg>
                        Videos
                    </a>
                    <a href="{{ path('admin_categories') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_categories' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
                        </svg>
                        Categories
                    </a>
                    <a href="{{ path('admin_tags') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_tags' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                        </svg>
                        Tags
                    </a>
                    <a href="{{ path('admin_comments') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_comments' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                        </svg>
                        Comments
                    </a>
                </div>

                <div class="mt-4">
                    <div class="px-3 py-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Users</div>
                    <a href="{{ path('admin_users') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_users' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                        </svg>
                        Users
                    </a>
                    <a href="{{ path('admin_roles') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_roles' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                        </svg>
                        Roles
                    </a>
                    <a href="{{ path('admin_permissions') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_permissions' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
                        </svg>
                        Permissions
                    </a>
                    <a href="{{ path('admin_models') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_models' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
                        </svg>
                        Models
                    </a>
                </div>

                <div class="mt-4">
                    <div class="px-3 py-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Settings</div>
                    <a href="{{ path('admin_settings') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') == 'admin_settings' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        Settings
                    </a>
                    <a href="{{ path('admin_storage') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_storage' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path>
                        </svg>
                        Storage
                    </a>
                    <a href="{{ path('admin_transcoding_settings') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') == 'admin_transcoding_settings' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                        </svg>
                        Transcoding
                    </a>
                    <a href="{{ path('admin_encoding_profiles') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') starts with 'admin_encoding_profiles' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
                        </svg>
                        Encoding Profiles
                    </a>
                </div>

                <div class="mt-4">
                    <div class="px-3 py-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">System</div>
                    <a href="{{ path('admin_system_messenger') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') == 'admin_system_messenger' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                        </svg>
                        Queue
                    </a>
                    <a href="{{ path('admin_system_rate_limiter') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') == 'admin_system_rate_limiter' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                        </svg>
                        Rate Limits
                    </a>
                    <a href="{{ path('admin_system_mailer') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white {{ app.request.attributes.get('_route') == 'admin_system_mailer' ? 'bg-gray-800 text-white border-r-2 border-blue-500' : '' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>
                        Email
                    </a>
                </div>

                <div class="mt-4 border-t border-gray-800 pt-3">
                    <a href="{{ path('app_home') }}" class="flex items-center gap-2 px-3 py-2 mx-2 text-sm text-gray-300 hover:bg-gray-800 hover:text-white">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        Back to site
                    </a>
                </div>
            </nav>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col">
            <!-- Top Bar -->
            <header class="bg-white border-b border-gray-200">
                <div class="flex items-center justify-between px-4 py-3">
                    <h2 class="text-xl font-semibold text-gray-900">{% block page_title %}Admin Panel{% endblock %}</h2>
                    <div class="flex items-center gap-3">
                        {# Theme Switcher #}
                        <button 
                            data-theme-toggle
                            class="theme-switcher"
                            title="Toggle theme"
                            aria-label="Toggle theme">
                            <svg data-theme-icon="light" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display: none;">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
                            </svg>
                            <svg data-theme-icon="dark" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                            </svg>
                        </button>
                        
                        <a href="{{ path('app_home') }}" target="_blank" class="text-sm text-gray-600">
                            View site
                        </a>
                        <span class="text-sm text-gray-600">{{ app.user.username }}</span>
                        <a href="{{ path('app_logout') }}" class="text-sm text-red-600 hover:text-red-800">Logout</a>
                    </div>
                </div>
            </header>

            <!-- Content Area -->
            <main class="p-2">
                {% for message in app.flashes('success') %}
                    <div class="mb-3 bg-green-50 border border-green-200 text-green-800 px-3 py-2 text-sm">
                        {{ message }}
                    </div>
                {% endfor %}

                {% for message in app.flashes('error') %}
                    <div class="mb-3 bg-red-50 border border-red-200 text-red-800 px-3 py-2 text-sm">
                        {{ message }}
                    </div>
                {% endfor %}

                {% for message in app.flashes('warning') %}
                    <div class="mb-3 bg-yellow-50 border border-yellow-200 text-yellow-800 px-3 py-2 text-sm">
                        {{ message }}
                    </div>
                {% endfor %}

                {% for message in app.flashes('info') %}
                    <div class="mb-3 bg-blue-50 border border-blue-200 text-blue-800 px-3 py-2 text-sm">
                        {{ message }}
                    </div>
                {% endfor %}

                {% block content %}{% endblock %}
            </main>
        </div>
    </div>
    
    {% block javascripts %}{% endblock %}
</body>
</html>
